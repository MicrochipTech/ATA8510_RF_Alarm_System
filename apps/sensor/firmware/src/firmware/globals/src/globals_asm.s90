    IN      R16 , EEDR  ; 8
    ST      Z+ , R16
    IN      R16 , EEDR  ; 9
    ST      Z+ , R16
    ; 120 - 125
    IN      R16 , EEDR  ; 0
    ST      Z+ , R16
    IN      R16 , EEDR  ; 1
    ST      Z+ , R16
    IN      R16 , EEDR  ; 2
    ST      Z+ , R16
    IN      R16 , EEDR  ; 3
    ST      Z+ , R16
    IN      R16 , EEDR  ; 4
    ST      Z+ , R16
    IN      R16 , EEDR  ; 5
    ST      Z+ , R16

    ; --SIX-3196--
    LDS     R30 , EECR2
    ANDI    R30 , ~BM_EEBRE
    STS     EECR2 , R30
    ; --SIX-3196--
    
    RET
    

/* ---------------------------------------------------------------------------*/
/** \brief <b>ATA_copyEepChannel_ASM</b>
    reads an eep service.
    
    \param dstPtr   in register R17:R16
    \param srcPtr   in register R19:R18
        
    \return none
*/
/* ---------------------------------------------------------------------------*/
RSEG CODE:CODE:ROOT(1)
ATA_copyEepChannel_ASM:
    SBIC    EECR , EEWE
    RJMP    ATA_copyEepChannel_ASM
    OUT     EEARH , R19
    OUT     EEARL , R18
    ; --SIX-3196--
    LDS     R30 , EECR2
    ORI     R30 , BM_EEBRE
    STS     EECR2 , R30
    ; --SIX-3196--
    
    MOVW    R30 , R16

    ; 0 - 4
    IN      R16 , EEDR  ; 0
    ST      Z+ , R16
    IN      R16 , EEDR  ; 1
    ST      Z+ , R16
    IN      R16 , EEDR  ; 2
    ST      Z+ , R16
    IN      R16 , EEDR  ; 3
    ST      Z+ , R16
    IN      R16 , EEDR  ; 4
    ST      Z+ , R16

    ; --SIX-3196--
    LDS     R30 , EECR2
    ANDI    R30 , ~BM_EEBRE
    STS     EECR2 , R30
    ; --SIX-3196--

    RET
    
