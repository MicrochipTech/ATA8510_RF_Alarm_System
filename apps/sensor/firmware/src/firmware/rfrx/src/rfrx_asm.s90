    NAME rfrx_asm

    PUBLIC ATA_wakeCheckOkPathB_ASM
    PUBLIC ATA_wakeCheckOkPathA_ASM

    PUBLIC ATA_startOfTelegramPathB_ASM
    PUBLIC ATA_startOfTelegramPathA_ASM

    PUBLIC ATA_endOfTelegramPathB_ASM
    PUBLIC ATA_endOfTelegramPathA_ASM

    PUBLIC ATA_dataFifoFillLevelReached_ASM
    PUBLIC ATA_rssiPreambleFifoFillLevelReached_ASM

    EXTERN ATA_setEventPin_ASM

    EXTERN currentService
    EXTERN trxConf
    EXTERN rssiAtWcok

    EXTERN frequencyOffsetAtWcok
    EXTERN rxIrqEvents
    EXTERN subChan

/* ===========================================================================*/
/*   INCLUDES                                                                 */
/* ===========================================================================*/
#include "regs.inc"
#include "globals.h"
#include "rfrx.h"

